# Copy this file to .env and fill in what you have. Every value below has a
# safe default baked into app/config.py, so the app boots and is fully
# demoable (via dry-run WhatsApp + the simulator panel) even with this file
# left almost empty - you only need to fill in real values for the pieces
# you want to exercise for real.

# --- Core service ------------------------------------------------------
ENVIRONMENT=development
PORT=8000

# --- MongoDB -------------------------------------------------------------
# docker-compose overrides this to mongodb://mongo:27017 automatically.
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=whatsapp_agent

# --- Meta / WhatsApp Cloud API --------------------------------------------
# From your Meta Business App > WhatsApp > API Setup.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_VERSION=v20.0

# Any string you choose - you'll re-enter the same value when configuring
# the webhook URL in the Meta App dashboard.
WHATSAPP_VERIFY_TOKEN=change-me-verify-token

# From App Settings > Basic > App Secret. Used to validate the
# X-Hub-Signature-256 header on every inbound webhook call (bonus security
# requirement). Leave blank during early local development and the
# verification check is skipped with a warning logged - never leave it
# blank in production.
WHATSAPP_APP_SECRET=

# Set to true to force every outbound WhatsApp call to be logged instead of
# actually sent, regardless of whether the tokens above are filled in. This
# is what makes the dashboard's "Simulate inbound" panel and the seeded demo
# data usable with zero Meta setup. Leave it true until you're ready to test
# against a real WhatsApp number.
DRY_RUN_WHATSAPP=true

# --- LLM provider ----------------------------------------------------------
# "openai" or "anthropic"
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Misc --------------------------------------------------------------------
# Comma-separated list, or "*" for any origin (fine for local dev).
CORS_ORIGINS=*

# Bonus: route a conversation to NEEDS_HUMAN when the LLM flags the
# customer as frustrated.
SENTIMENT_HANDOVER_ENABLED=true
